generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Persona {
  id           Int      @id @default(autoincrement())
  cc           String   @unique
  nombre       String
  sexo         String
  masaCorporal Float
  edad         Int
  talla        Float
  entrenado    Boolean
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  cintura      Float?
  cadera       Float?
  sesiones     Sesion[]

  @@index([createdAt])
}

model Ejercicio {
  id             Int                  @id
  nombre         String
  porcentajeMasa Float
  resultados     ResultadoEjercicio[]

  @@index([nombre])
}

model Sesion {
  id         Int                  @id @default(autoincrement())
  personaId  Int
  createdAt  DateTime             @default(now())
  requestId  String?              @unique
  peso       Float?
  resultados ResultadoEjercicio[]
  persona    Persona              @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@index([personaId, createdAt])
}

model ResultadoEjercicio {
  id           Int       @id @default(autoincrement())
  sesionId     Int
  ejercicioId  Int
  repeticiones Int
  carga        Float
  epley        Float
  brzycki      Float
  lombardi     Float
  lander       Float
  oconnor      Float
  mayhew       Float
  wathen       Float
  baechle      Float
  createdAt    DateTime  @default(now())
  casas        Float?
  nacleiro     Float?
  ejercicio    Ejercicio @relation(fields: [ejercicioId], references: [id])
  sesion       Sesion    @relation(fields: [sesionId], references: [id], onDelete: Cascade)

  @@index([sesionId, createdAt])
  @@index([ejercicioId])
}

model AdminOtp {
  id        Int      @id @default(autoincrement())
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  requestId String?  @unique

  @@index([code, used, expiresAt])
  @@index([createdAt])
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  password  String
  createdAt DateTime @default(now())
}
